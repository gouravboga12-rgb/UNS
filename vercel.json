{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend-web/dist"
      }
    },
    {
      "src": "backend/src/app.ts",
      "use": "@vercel/node",
      "config": {
        "tsconfig": "backend/tsconfig.json"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/app.ts"
    },
    {
      "src": "/products/(.*\\.(png|jpg|jpeg|gif|webp|svg))",
      "dest": "backend/src/app.ts"
    },
    {
      "src": "/banners/(.*\\.(png|jpg|jpeg|gif|webp|svg))",
      "dest": "backend/src/app.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
